# Telegram Bot Token
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase storage bucket used for temporary media delivery
SUPABASE_STORAGE_BUCKET=downloader-bot-media

# Optional cookies file for yt-dlp when YouTube asks for sign-in confirmation
YTDLP_YOUTUBE_COOKIES_FILE=cookies.txt

# Optional public URLs to cookies files stored in Supabase Storage
YTDLP_YOUTUBE_COOKIES_URL=https://your-project.supabase.co/storage/v1/object/public/downloader-bot-media/cookies.txt

# Optional cookies file for Instagram/TikTok extraction
YTDLP_SOCIAL_COOKIES_FILE=cookies2.txt

# Optional public URL to social cookies file stored in Supabase Storage
YTDLP_SOCIAL_COOKIES_URL=https://your-project.supabase.co/storage/v1/object/public/downloader-bot-media/cookies2.txt

# Forced channel subscription (optional)
# Channel ID where users must subscribe to use the bot
# Get channel ID from @userinfobot on Telegram or from channel link
FORCED_CHANNEL_ID=
# Channel username (with @) for display and links
CHANNEL_USERNAME=@YourChannel
